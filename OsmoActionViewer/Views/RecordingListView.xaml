<UserControl x:Class="OsmoActionViewer.Views.RecordingListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel LastChildFill="True" Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="0,0,0,12">
            <TextBlock Text="Library" FontSize="24" FontWeight="SemiBold" />
            <TextBlock Text="フォルダ内の動画をセクションごとに閲覧"
                       Margin="0,4,0,14"
                       Foreground="{StaticResource MutedTextBrush}" />

            <Button x:Name="ChooseFolderButton"
                    Content="Select Folder..."
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10"
                    Click="ChooseFolderButton_Click" />

            <Border Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Current Folder" FontWeight="SemiBold" />
                    <TextBlock x:Name="FolderPathText"
                               Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>
            </Border>

            <TextBlock Text="Section" FontWeight="SemiBold" Margin="0,0,0,6" />
            <ComboBox x:Name="SectionCombo" Margin="0,0,0,12" SelectionChanged="SectionCombo_SelectionChanged" />

            <UniformGrid Columns="2" Margin="0,0,0,8">
                <Button x:Name="SelectAllButton"
                        Content="Select All"
                        Margin="0,0,8,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="SelectAllButton_Click" />
                <Button x:Name="ClearCheckButton"
                        Content="Clear"
                        Margin="0,0,0,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="ClearCheckButton_Click" />
                <Button x:Name="DeleteCheckedButton"
                        Content="Delete"
                        Margin="0,0,8,0"
                        Style="{StaticResource DangerButtonStyle}"
                        Click="DeleteCheckedButton_Click" />
                <Button x:Name="ExportHighlightsButton"
                        Content="Export Highlights"
                        Click="ExportHighlightsButton_Click" />
            </UniformGrid>
        </StackPanel>

        <ListBox x:Name="RecordingListBox" SelectionChanged="RecordingListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox x:Name="CheckBox"
                                  Grid.Column="0"
                                  VerticalAlignment="Center"
                                  Margin="0,0,10,0"
                                  Tag="{Binding Id}"
                                  IsChecked="{Binding IsChecked}"
                                  Click="CheckBox_Click" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding DisplayName}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
