<UserControl x:Class="OsmoActionViewer.Views.RecordingDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Player" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12" />

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource SurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="12"
                    Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <MediaElement x:Name="Media"
                                  Grid.Row="0"
                                  Height="420"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Stop"
                                  ScrubbingEnabled="True"
                                  MediaOpened="Media_MediaOpened"
                                  MediaFailed="Media_MediaFailed"
                                  MediaEnded="Media_MediaEnded" />

                    <Slider x:Name="SeekBar"
                            Grid.Row="1"
                            Margin="0,12,0,2"
                            Minimum="0"
                            SmallChange="1"
                            LargeChange="10"
                            PreviewMouseLeftButtonDown="SeekBar_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="SeekBar_PreviewMouseLeftButtonUp"
                            LostMouseCapture="SeekBar_LostMouseCapture"
                            ValueChanged="SeekBar_ValueChanged" />

                    <DockPanel Grid.Row="2" Margin="0,8,0,0" LastChildFill="False">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button x:Name="Back10Button"
                                    Content="&lt;&lt; -10s"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="Back10Button_Click" />
                            <Button x:Name="PlayPauseButton"
                                    Content="Play/Pause"
                                    Margin="0,0,8,0"
                                    Click="PlayPauseButton_Click" />
                            <Button x:Name="Forward10Button"
                                    Content="+10s &gt;&gt;"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="Forward10Button_Click" />
                        </StackPanel>
                        <TextBlock x:Name="TimeText"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold" />
                    </DockPanel>
                </Grid>
            </Border>

            <GroupBox Grid.Row="3" Header="Title / Location" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Title" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox x:Name="TitleBox" Margin="0,0,0,10" TextChanged="MetadataField_TextChanged" />

                    <TextBlock Text="Location" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <TextBox x:Name="LocationBox" Margin="0,0,0,10" TextChanged="MetadataField_TextChanged" />

                    <TextBlock Text="Google Maps URL" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="GMapsBox"
                                 Grid.Column="0"
                                 Margin="0,0,8,0"
                                 TextChanged="MetadataField_TextChanged" />
                        <Button x:Name="OpenGMapsButton"
                                Grid.Column="1"
                                Content="Open"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="OpenGMapsButton_Click" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="4" Header="Markers" Margin="0,0,0,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="MarkerSecondsBox" Width="80" Margin="0,0,4,0" />
                        <Button x:Name="AddMarkerButton" Content="Add from input" Click="AddMarkerButton_Click" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button x:Name="AddNowMarkerButton" Content="Add at current time" Click="AddNowMarkerButton_Click" />
                    </StackPanel>
                    <ListBox x:Name="MarkerList" Height="80" Margin="0,6,0,0" />
                    <Button x:Name="RemoveMarkerButton" Content="Remove selected" Click="RemoveMarkerButton_Click" HorizontalAlignment="Left" Margin="0,8,0,0" Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="5" Header="Highlight Export" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Clip seconds:" VerticalAlignment="Center" Margin="0,0,4,0" />
                    <TextBox x:Name="ClipDurationBox" Width="60" Text="10" Margin="0,0,8,0" />
                    <Button x:Name="ExportHighlightsButton"
                            Content="Export Highlights"
                            Click="ExportHighlightsButton_Click" />
                </StackPanel>
            </GroupBox>

            <GroupBox Grid.Row="6" Header="Clip Range Export" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="StartBox" Width="60" Margin="0,0,4,0" />
                    <Button x:Name="StartNowButton" Content="now" Click="StartNowButton_Click" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" />
                    <TextBox x:Name="EndBox" Width="60" Margin="0,0,4,0" />
                    <Button x:Name="EndNowButton" Content="now" Click="EndNowButton_Click" Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}" />
                    <Button x:Name="ExportRangeButton"
                            Content="Export clip"
                            Click="ExportRangeButton_Click" />
                </StackPanel>
            </GroupBox>

            <StackPanel Grid.Row="7">
                <TextBlock Text="{Binding ExportStatusMessage}"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,6"
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="ExportProgressBar"
                             Minimum="0"
                             Maximum="1"
                             Height="10"
                             Margin="0,0,0,8"
                             Value="{Binding ExportProgressValue}"
                             IsIndeterminate="{Binding ExportProgressIndeterminate}" />
                <TextBlock x:Name="ErrorText" Foreground="Red" Margin="0,0,0,4" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
